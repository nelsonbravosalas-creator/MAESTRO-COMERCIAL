# Database
# For Neon: postgresql://user:password@[project].neon.tech/bravocrm
# For local PostgreSQL: postgresql://user:password@localhost:5432/bravocrm
DATABASE_URL=postgresql://user:password@localhost:5432/bravocrm

# JWT Configuration
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRY=7d

# Admin setup (POST /api/admin/setup) - crea/promueve un usuario a admin.
# Dejar SIN definir deshabilita el endpoint (responde 503).
ADMIN_SETUP_SECRET=change-this-to-a-long-random-secret

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Frontend (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: Neon specific
# NEON_API_KEY=your-neon-api-key-if-needed
